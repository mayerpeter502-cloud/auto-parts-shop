# Telegram Notifications (Optional)
# Instructions: Create a bot via @BotFather to get the token
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email Configuration (SMTP)
# Used for sending order confirmations
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Payment Gateway (Integration Placeholder)
KASPI_MERCHANT_ID=your_merchant_id
KASPI_SECRET_KEY=your_secret_key

# Database / API Configuration
# Current version uses LocalStorage for demo. 
# Update this URL when connecting your own backend/database.
NEXT_PUBLIC_API_URL=http://localhost:3000